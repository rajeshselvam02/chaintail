{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@chaintail/shared": ["../shared/src/index.ts"],
      "@chaintail/node-connector": ["../node-connector/src/index.ts"]
    },
    "baseUrl": "."
  },
  "exclude": ["node_modules", "dist"]
}
