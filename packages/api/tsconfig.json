{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@chaintail/shared": [
        "../shared/src/index.ts"
      ],
      "@chaintail/node-connector": [
        "../node-connector/src/index.ts"
      ],
      "@chaintail/graph-tracer": [
        "../graph-tracer/src/index.ts"
      ],
      "@chaintail/clustering": [
        "../clustering/src/index.ts"
      ],
      "@chaintail/entity-labels": [
        "../entity-labels/src/index.ts"
      ],
      "@chaintail/case-manager": [
        "../case-manager/src/index.ts"
      ],
      "@chaintail/pattern-detector": [
        "../pattern-detector/src/index.ts"
      ],
      "@chaintail/ml-scorer": [
        "../ml-scorer/src/index.ts"
      ],
      "@chaintail/eth-connector": [
        "../eth-connector/src/index.ts"
      ],
      "@chaintail/saas": [
        "../saas/src/index.ts"
      ]
    },
    "baseUrl": "."
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}